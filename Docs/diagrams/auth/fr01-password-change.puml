@startuml
!theme plain
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #333
skinparam sequenceLifeLineBorderColor #999
skinparam noteBorderColor #CCC
skinparam noteBackgroundColor #FEFCE8
skinparam sequenceGroupBorderColor #666
skinparam defaultFontSize 11

title **FR-01: Authenticated Password Change**\nPATCH /api/v1/auth/password\n<size:10>Auth: IsAuthenticated | No throttle</size>

actor       "Client"     as C
participant "Frontend"   as FE  #E8F4FD
participant "ChangePasswordView\n(views.py:545)" as V  #E8F0E8
participant "PasswordChangeSerializer\n(serializers.py:257)" as S  #E8F0E8
participant "Utils\n(_utils.py)"  as U  #FFF3E0
participant "AuthService\n(_auth.py)" as A  #FFF3E0
database    "PostgreSQL" as DB #F3E5F5

== Request ==
C -> FE : Enter current + new + confirm password
FE -> V : PATCH /api/v1/auth/password\nAuthorization: Bearer {access_token}\n**{currentPassword, newPassword, confirmPassword}**

== Serializer Validation ==
V -> S : validate(request.data)
note right of S
  Fields (all trim_whitespace=False):
  - currentPassword: CharField(max=255)
  - newPassword: CharField(max=255)
  - confirmPassword: CharField(max=255)
end note
alt #FFE0E0 missing fields
  S --> V : ValidationError
  V --> FE : **400** {field: ["required"]}
end

== Password Match Check ==
V -> V : newPassword == confirmPassword?
alt #FFE0E0 mismatch
  V --> FE : **400** {"detail": "Passwords do not match."}
  FE --> C : Show error
end

== Current Password Verification ==
V -> DB : request.user.check_password(currentPassword)
note right of DB
  PBKDF2_SHA256 comparison
  against stored hash in
  accounts_user.password
end note
alt #FFE0E0 wrong current password
  V --> FE : **400** {"detail": "Current password is incorrect."}
  FE --> C : Show error
end

== New Password Strength Validation ==
V -> U : password_strength_errors(newPassword)
note right of U
  Policy checks (returns list of failures):
  1. len >= 8 → "Password must be at least 8 characters."
  2. [A-Z] present → "...at least one uppercase letter."
  3. [a-z] present → "...at least one lowercase letter."
  4. [0-9] present → "...at least one number."
  5. special char → "...at least one special character."
end note
alt #FFE0E0 any policy violated
  U --> V : errors = ["first failure message", ...]
  V --> FE : **400** {"detail": errors[0]}
  FE --> C : Show password policy error
end

== Same-Password Check ==
V -> DB : request.user.check_password(newPassword)
alt #FFE0E0 new == current
  V --> FE : **400** {"detail": "New password must be\ndifferent from current password."}
  FE --> C : Show error
end

== Apply Change ==
V -> DB : user.set_password(newPassword)
note right of DB
  Django hashes with PBKDF2_SHA256:
  hash = pbkdf2_sha256${iterations}${salt}${hash}
end note
V -> DB : user.save(update_fields=["password"])
note right of DB
  UPDATE accounts_user
  SET password={new_hash}
  WHERE id={user.id}
end note

== Invalidate All Sessions ==
V -> A : invalidate_user_sessions(request.user)
A -> DB : Blacklist ALL outstanding\nrefresh tokens for user
note right of A
  Forces re-login on all devices.
  Access tokens remain valid
  until short expiry (~5 min).
end note
A --> V : count = N sessions invalidated

== Response ==
V --> FE : **200** OK
note right of V
  {
    "message": "Password changed successfully.",
    "sessionsInvalidated": 3
  }
end note
FE --> C : Show success + redirect to login\n(current session also invalidated)

@enduml
