@startuml
!theme plain
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #333
skinparam sequenceLifeLineBorderColor #999
skinparam noteBorderColor #CCC
skinparam noteBackgroundColor #FEFCE8
skinparam sequenceGroupBorderColor #666
skinparam defaultFontSize 11

title **FR-01: Password Reset (Full Lifecycle)**\nIssuance → Verification → Completion\n<size:10>Three endpoints, one-time-use codes, 30-minute expiry</size>

actor       "Issuer\n(Teacher/Admin/\nResearcher)" as I
actor       "Target User"  as T
participant "Frontend"     as FE  #E8F4FD
participant "Views\n(views.py)"    as V  #E8F0E8
participant "ResetService\n(_password_reset.py)" as RS  #FFF3E0
participant "Utils\n(_utils.py)"   as U  #FFF3E0
database    "PostgreSQL"   as DB #F3E5F5

== PHASE 1: Code Issuance ==
note over I, DB
  **POST /api/v1/auth/password-reset-codes**
  Auth: IsTeacherOrAbove | No throttle
  Request: **{targetUserId: int}** (StrictFieldsSerializer — rejects unknown fields)
end note

I -> FE : Click "Issue Reset" for target
FE -> V : POST /api/v1/auth/password-reset-codes\nAuthorization: Bearer {issuer_token}\n**{targetUserId: 99}**

V -> RS : issue_password_reset_code(\n  issuer=request.user,\n  target_user_id=99)
note right of RS : @transaction.atomic

RS -> DB : SELECT * FROM accounts_user\nWHERE id=99\nFOR UPDATE
alt #FFE0E0 target not found
  RS --> V : ValueError("Target user not found.")
  V --> FE : **404** {"detail": "Target user not found."}
end

=== Authorization Tree ===

RS -> RS : _authorize_reset_issuance(\n  issuer, target)

alt #FFE0E0 issuer.id == target.id
  RS --> V : PermissionError("Permission denied.")
  V --> FE : **403** {"detail": "Permission denied."}
  note right of V: SUDO-CN-13: self-issuance\nuniversally blocked.\nGeneric message hides rule.
else #FFE0E0 target.is_staff (admin)
  RS --> V : PermissionError("Reset codes cannot\nbe issued for admin accounts.")
  V --> FE : **403**
else #FFE0E0 target role not STUDENT/TEACHER/RESEARCHER
  RS --> V : PermissionError("Target role is not\neligible for reset issuance.")
  V --> FE : **403**
end

alt issuer.is_staff (admin)
  RS -> RS : ALLOWED (admin can reset any non-admin)
else issuer role = TEACHER
  alt #FFE0E0 target role != STUDENT
    RS --> V : PermissionError("Teachers can only issue\nreset codes for students.")
    V --> FE : **403**
  end
  RS -> DB : SELECT EXISTS FROM courses_enrollment\nWHERE student_profile.user={target}\n  AND status='ACTIVE'\n  AND course.teacher_profile.user={issuer}
  alt #FFE0E0 student not enrolled in teacher's courses
    RS --> V : PermissionError("Student is not enrolled\nin your courses.")
    V --> FE : **403**
  end
  RS -> RS : ALLOWED
else issuer role = RESEARCHER
  alt target role = TEACHER
    RS -> RS : ALLOWED (default: researchers can reset teachers)
  else target role = STUDENT
    RS -> DB : has_sudo_permission(issuer,\n  ISSUE_STUDENT_RESET_CODE)
    alt #FFE0E0 no sudo permission
      RS --> V : PermissionError("Not authorized...")
      V --> FE : **403**
    end
    RS -> RS : ALLOWED
  else target role = RESEARCHER
    RS -> DB : has_sudo_permission(issuer,\n  ISSUE_RESEARCHER_RESET_CODE)
    alt #FFE0E0 no sudo permission
      RS --> V : PermissionError("Not authorized...")
      V --> FE : **403**
    end
    RS -> RS : ALLOWED
  end
else #FFE0E0 any other role (STUDENT, etc.)
  RS --> V : PermissionError("Not authorized\nto issue reset codes.")
  V --> FE : **403**
end

=== Expire Previous Codes ===

RS -> DB : UPDATE password_reset_requests\nSET status='EXPIRED',\n    reviewed_by={issuer},\n    reviewed_at=NOW()\nWHERE user={target}\n  AND status IN ('PENDING','APPROVED')
note right of DB: Invalidates any prior\nactive codes for this target

=== Generate New Code ===

RS -> U : _generate_secret_token("REQ")
note right of U
  Format: "REQ-{24 hex chars}"
  Source: secrets.token_hex(12).upper()
end note
U --> RS : req_token = "REQ-A1B2C3..."
RS -> U : _hash_secret_token(req_token)
note right of U
  hashlib.sha256(
    req_token.encode()
  ).hexdigest()
  → 64 char hex string
end note
U --> RS : req_hash

RS -> DB : INSERT INTO password_reset_requests\n(user_id={target}, identifier={target.username.lower()},\n requested_role={primary_role(target)},\n request_token_hash={req_hash},\n status='APPROVED',\n reason='Issuer-generated reset code.',\n expires_at=NOW()+30min,\n reviewed_by={issuer}, reviewed_at=NOW())

RS -> U : _generate_secret_token("RESET")
U --> RS : reset_code = "RESET-D4E5F6..."
RS -> U : _hash_secret_token(reset_code)
U --> RS : code_hash (SHA256)

RS -> DB : INSERT INTO password_reset_codes\n(request_id={req.id},\n code_hash={code_hash},\n expires_at={req.expires_at},\n used_at=NULL)

note right of DB #FEFCE8
  **Stored in DB:** SHA256 hash only
  **Returned to caller:** plaintext code
  Code can NEVER be recovered from DB
end note

RS --> V : (reset_request, "RESET-D4E5F6...")
V --> FE : **201** Created
note right of V
  {
    "requestId": 42,
    "targetUserId": 99,
    "targetRole": "STUDENT",
    "resetCode": "RESET-D4E5F6...",
    "expiresAt": "2026-02-23T15:30:00Z"
  }
end note
FE -> I : Show code in ResetCodeDialog\n(one-time display, copy button,\n30-min expiry warning)
I --> T : Deliver code out-of-band\n(verbal, email, printed)

|||
== PHASE 2: Code Verification (Optional) ==
note over T, DB
  **POST /api/v1/auth/reset-code-validations**
  Auth: None (AllowAny) | Throttle: AnonBurstThrottle (5/min)
end note

T -> FE : Navigate to /forgot-password
FE -> V : POST /api/v1/auth/reset-code-validations\n**{identifier: "student01", resetCode: "RESET-D4E5F6..."}**

V -> RS : verify_password_reset_code(\n  identifier, reset_code)
RS -> DB : find_user_by_identifier("student01")\nSELECT * WHERE username ILIKE ...\n(then email ILIKE if no match)
alt #FFE0E0 user not found
  RS --> V : None
  V --> FE : **400** {"valid": false,\n"detail": "Invalid or expired reset code."}
end

RS -> U : _hash_secret_token(reset_code)
U --> RS : code_hash (SHA256)
RS -> DB : SELECT * FROM password_reset_codes\nJOIN password_reset_requests\nWHERE code_hash={hash}\n  AND request.user_id={user.id}\n  AND request.status='APPROVED'\n  AND used_at IS NULL\nLIMIT 1
alt #FFE0E0 no matching code
  RS --> V : None
  V --> FE : **400** {"valid": false,\n"detail": "Invalid or expired reset code."}
end

RS -> RS : code.expires_at > NOW()?
alt #FFE0E0 expired
  RS -> DB : UPDATE request SET status='EXPIRED',\nreviewed_at=NOW()
  RS --> V : None
  V --> FE : **400** {"valid": false,\n"detail": "Invalid or expired reset code."}
end

RS --> V : code object
V --> FE : **200** {"valid": true,\n"requestId": 42,\n"expiresAt": "..."}

|||
== PHASE 3: Reset Completion ==
note over T, DB
  **POST /api/v1/auth/password-resets**
  Auth: None (AllowAny) | Throttle: AnonBurstThrottle (5/min)
  @transaction.atomic
end note

T -> FE : Enter new password + confirm
FE -> V : POST /api/v1/auth/password-resets\n**{identifier, resetCode,\nnewPassword, confirmPassword}**

V -> V : newPassword == confirmPassword?
alt #FFE0E0 mismatch
  V --> FE : **400** {"detail": "Passwords do not match."}
end

V -> RS : complete_password_reset(\n  identifier, reset_code, new_password)
note right of RS : @transaction.atomic

RS -> DB : find_user_by_identifier(identifier)
alt #FFE0E0 user not found
  RS --> V : PermissionError("Invalid reset code.")
  V --> FE : **400** {"detail": "Invalid reset code."}
end

RS -> U : _hash_secret_token(reset_code)
RS -> DB : SELECT * FROM password_reset_codes\nJOIN password_reset_requests\nWHERE code_hash={hash}\n  AND request.user_id={user.id}\n  AND request.status='APPROVED'\n  AND used_at IS NULL\n**FOR UPDATE**
note right of DB: Row-level lock prevents\nconcurrent redemption

alt #FFE0E0 no matching code
  RS --> V : PermissionError("Invalid reset code.")
  V --> FE : **400**
end

RS -> RS : code.expires_at > NOW()?
alt #FFE0E0 expired
  RS -> DB : UPDATE request SET status='EXPIRED'
  RS --> V : PermissionError("Reset code has expired.")
  V --> FE : **400** {"detail": "Reset code has expired."}
end

RS -> U : password_strength_errors(new_password)
alt #FFE0E0 policy violation
  RS --> V : ValueError(first_error)
  V --> FE : **400** {"detail": "Password must include..."}
end

RS -> DB : user.check_password(new_password)
alt #FFE0E0 same as current
  RS --> V : ValueError("New password must be\ndifferent from current password.")
  V --> FE : **400**
end

RS -> DB : user.set_password(new_password)\n→ PBKDF2_SHA256 hash
RS -> DB : UPDATE accounts_user\nSET password={new_hash}\nWHERE id={user.id}

RS -> DB : UPDATE password_reset_codes\nSET used_at=NOW()\nWHERE id={code.id}
note right of DB #FEFCE8
  **One-time use enforced:**
  used_at is set, so future queries
  with used_at IS NULL won't match.
  All within same atomic transaction.
end note

RS --> V : user
V --> FE : **200** {"message": "Password reset successful."}
FE --> T : Show success + "Back to login" link

@enduml
