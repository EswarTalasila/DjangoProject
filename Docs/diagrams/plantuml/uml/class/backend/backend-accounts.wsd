}
class UserRoleAdmin {
}
class StudentProfileAdmin {
}
class TeacherProfileAdmin {
}
class OAuthAccountAdmin {
}
class Command {
  +add_arguments(parser: Any): Any
  +handle(): Any
  +_ensure_user(username: Any, name: Any, password: Any, role: Any, force_password: Any): Any
}
}

@enduml
