@startuml
hide circle
skinparam classAttributeIconSize 0

package "submissions" {
class submissionsServices <<Service>> {
  +submission_to_dto(submission: Submission): dict
  +submission_to_compact_dto(submission: Submission): dict
  +answer_to_dto(answer: Answer): dict
  +create_submission(assignment_id: int, payload: dict, status: str): Submission
  +submit_teacher_self_assessment(creator_user_id: int, assessment_id: int, answers: list): Submission
  +get_submission(submission_id: int): Submission
  +get_by_assignment(assignment_id: int): List[Submission]
  +get_by_student(student_id: int): List[Submission]
  +get_by_teacher(teacher_id: int): List[Submission]
  +get_by_student_and_assignment(student_id: int, assignment_id: int): Submission
  +list_mine(user_id: int, status: Optional[str]): List[dict]
  +edit_submission(payload: dict): Submission
  +override_score(submission_id: int, scores: list): Submission
  +_find_existing_submission(assignment_id: int, student_id: Optional[int], teacher_id: Optional[int]): Optional[Submission]
  +_replace_answers(submission: Submission, answers: Iterable[dict]): None
  +_create_answer(submission: Submission, payload: dict): Answer
  +_auto_score_submission(submission: Submission, assessment: Assessment): None
  +_auto_score_mcq(answer: Answer, question: Question): float
  +_auto_score_number_scale(answer: Answer, question: Question): float
}
class AnswerSerializer {
}
class SubmissionSerializer {
}
class SubmissionAdmin {
}
class AnswerAdmin {
}
}

@enduml
