@startuml
autonumber
participant Client
database Postgres
participant "eel-backend"

Client ->> "eel-backend": POST api/v1/registration/code-validations
"eel-backend" ->> Postgres: SELECT registration_codes WHERE code_hash = ?
"eel-backend" ->> Postgres: SELECT courses WHERE id = ?
"eel-backend" ->> Postgres: SELECT teacher_profiles WHERE id = ?
"eel-backend" ->> Postgres: SELECT app_users WHERE id = ?
"eel-backend" -->> Client: HTTP 200
@enduml
