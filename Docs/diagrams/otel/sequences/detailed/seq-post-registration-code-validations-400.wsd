@startuml
title POST /api/v1/registration/code-validations (400 Invalid Code)
autonumber

actor Client
participant "validate_registration\n_code_view" as View
participant "RegistrationCode\nValidateInputSerializer" as Serializer
participant "validate_registration\n_code()" as Service
database Postgres

Client -> View: POST /registration/code-validations\n{code: "INVALID-CODE"}
View -> Serializer: is_valid(data)
Serializer --> View: validated {code}

View -> Service: validate_registration_code(code)
Service -> Service: _registration_code_hashes_for_lookup(code)
Service -> Postgres: SELECT registration_codes\nWHERE code_hash = ?
Postgres --> Service: NULL (not found)
Service --> View: None

View --x Client: 400 Bad Request\n{detail: "Invalid or expired code"}
@enduml
