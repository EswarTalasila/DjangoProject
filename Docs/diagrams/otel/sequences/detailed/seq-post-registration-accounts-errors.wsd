@startuml
title POST /api/v1/registration/accounts — Error Paths
autonumber

actor Client
participant "register_account()\n_register_local()" as View
participant "Serializer" as Serializer
participant "password_strength\n_errors()" as PwdCheck
participant "validate_registration\n_code()" as Validate
participant "redeem service" as Redeem
database Postgres

== Error: Invalid method ==
Client -> View: POST {method: "INVALID"}
View --x Client: 400 "method must be LOCAL or OAUTH"

== Error: Serializer validation failure ==
Client -> View: POST {method: "LOCAL", ...}
View -> Serializer: is_valid(raise_exception=True)
Serializer --x Client: 400 {field: [errors]}

== Error: Password mismatch ==
Client -> View: POST {method: "LOCAL",\npassword: "abc", confirmPassword: "xyz"}
View -> Serializer: is_valid()
Serializer --> View: OK
View -> View: password != confirmPassword
View --x Client: 400 "Passwords do not match"

== Error: Weak password ==
Client -> View: POST {method: "LOCAL",\npassword: "weak"}
View -> PwdCheck: password_strength_errors("weak")
PwdCheck --> View: ["Must be >= 8 chars",\n"Missing uppercase", ...]
View --x Client: 400 {detail: "Password does not\nmeet requirements", errors: [...]}

== Error: Invalid/expired code ==
Client -> View: POST {method: "LOCAL", code: "BAD"}
View -> Validate: validate_registration_code("BAD")
Validate -> Postgres: SELECT registration_codes\nWHERE code_hash = ?
Postgres --> Validate: NULL or expired/inactive
Validate --> View: None
View --x Client: 400 "Invalid or expired code"

== Error: Email already taken (non-student) ==
Client -> View: POST {method: "LOCAL", code: TEACHER_CODE}
View -> Validate: validate_registration_code()
Validate --> View: RegistrationCode (TEACHER)
View -> Redeem: redeem_non_student_local_invite()
Redeem -> Postgres: SELECT EXISTS app_users\nWHERE email = ?
Postgres --> Redeem: True (already exists)
Redeem --x View: ValueError("Email already taken")
View --x Client: 400 "Email already taken"

== Error: OAuth token invalid ==
Client -> View: POST {method: "OAUTH",\naccessToken: "invalid"}
View -> View: _google_userinfo("invalid")
View -> View: HTTP error from Google API
View --x Client: 401 "Invalid Google access token"

== Error: OAuth account already linked ==
Client -> View: POST {method: "OAUTH", ...}
View -> Redeem: redeem_non_student_oauth_invite()
Redeem -> Postgres: SELECT EXISTS oauth_accounts\nWHERE subject = ?
Postgres --> Redeem: True (already linked)
Redeem --x View: ValueError("OAuth account already linked")
View --x Client: 400 "OAuth account already linked"
@enduml
