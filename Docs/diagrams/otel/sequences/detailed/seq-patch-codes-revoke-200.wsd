@startuml
title PATCH /api/v1/codes/<id> — Revoke & Archive
autonumber

actor Client
participant "code_detail()" as View
participant "RegistrationCode\nUpdateSerializer" as Serializer
participant "transition_registration\n_code_status()" as Service
database Postgres

== Revoke an ACTIVE code ==
Client -> View: PATCH /codes/42\n{status: "REVOKED"}\n[JWT: teacher]
View -> Serializer: is_valid()
Serializer --> View: {status: "REVOKED"}

View -> Service: transition_registration_code_status(\nactor, code_id=42, next="REVOKED")

Service -> Postgres: SELECT registration_codes\nWHERE id=42 AND (scoped to user)\nFOR UPDATE
Postgres --> Service: RegistrationCode (locked)

Service -> Service: registration_code_status()\n-> current = ACTIVE
Service -> Service: validate: ACTIVE -> REVOKED? OK

Service -> Postgres: UPDATE registration_codes\nSET is_active = False
Service --> View: updated code

View -> View: _serialize_registration_code()
View --> Client: 200 OK\n{id: 42, status: "REVOKED", ...}

== Then archive the REVOKED code ==
Client -> View: PATCH /codes/42\n{status: "ARCHIVED"}
View -> Service: transition_registration_code_status(\nactor, code_id=42, next="ARCHIVED")

Service -> Postgres: SELECT registration_codes\nWHERE id=42 FOR UPDATE
Postgres --> Service: code (is_active=False)
Service -> Service: current = REVOKED\nvalidate: REVOKED -> ARCHIVED? OK

Service -> Postgres: UPDATE registration_codes\nSET archived_at = now()
Service --> View: updated code

View --> Client: 200 OK\n{id: 42, status: "ARCHIVED", ...}

note over Service
  **Valid transitions:**
  ACTIVE -> REVOKED
  EXHAUSTED -> ARCHIVED
  EXPIRED -> ARCHIVED
  REVOKED -> ARCHIVED
  (all others rejected with 400)
end note
@enduml
