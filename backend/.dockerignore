# =============================================================================
# Backend .dockerignore
# =============================================================================
# Excludes files from Docker build context to speed up builds and reduce image size.
# This file prevents unnecessary files from being sent to the Docker daemon.

# -----------------------------------------------------------------------------
# Python bytecode and cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Testing artifacts
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
wheels/
sdist/

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git/
.gitignore

# -----------------------------------------------------------------------------
# Documentation (built separately if needed)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# Local environment files
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
._*
