# EE-Lab Environment Configuration (Compatibility Template)
# Primary profile templates now live under env/:
#   - env/.env.development.template
#   - env/.env.testing.template
#   - env/.env.production.template
# Create runtime files with: task env:init

# =============================================================================
# Runtime Profile (FR-12)
# Allowed values: development | testing | production
# Default behavior in code is development when unset.
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# Django Core
# =============================================================================
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
# DJANGO_DEBUG is profile-derived in Docker (development=true, testing/production=false).
# Only set DJANGO_DEBUG for non-Docker local runs when debugging startup behavior.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,eel-backend,eel-frontend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost
# Optional overrides for internal demo environments running production profile on plain HTTP:
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_SESSION_COOKIE_SECURE=false
# DJANGO_CSRF_COOKIE_SECURE=false

# =============================================================================
# Database (Docker defaults)
# =============================================================================
POSTGRES_DB=eelab
POSTGRES_USER=eelab
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://eelab:change-me@database:5432/eelab

# =============================================================================
# OAuth (required in production)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Frontend Runtime
# =============================================================================
# Browser API base: relative path, resolved by nginx proxy.
# App entrypoint: http://localhost:8080 (dev/test), https://host (prod)
NEXT_PUBLIC_API_URL=/api/v1

# =============================================================================
# Admin Bootstrap (always bootstrapped; strict checks in production)
# =============================================================================
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# =============================================================================
# Observability
# development: default on (configurable)
# testing: default on
# production: opt-in only (OTLP exporter required; no local file exporter)
# =============================================================================
OTEL_ENABLED=
OTEL_SERVICE_NAME=eel-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACE_FILE=Docs/diagrams/otel/traces.jsonl

# =============================================================================
# E2E Runner (optional overrides; seed defaults are authoritative)
# =============================================================================
E2E_BASE_URL=http://localhost:8080
E2E_API_URL=http://localhost:8080/api/v1
E2E_USE_DOCKER=true
# Optional identity overrides:
# E2E_ADMIN_USERNAME=
# E2E_ADMIN_PASSWORD=
# E2E_TEACHER_USERNAME=
# E2E_TEACHER_PASSWORD=
# E2E_STUDENT_USERNAME=
# E2E_STUDENT_PASSWORD=
