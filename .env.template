# Lattice canonical environment template
# Edit this file only through .env after copying, then run:
#   task env:local   or   task env:server
#   task env:init

# Topology target
ENV_TARGET=server
PUBLIC_HOST=domain.com
PUBLIC_SCHEME=https

# Django core
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY

# Database
POSTGRES_DB=lattice_prod
POSTGRES_USER=lattice_prod
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# OAuth
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Admin bootstrap
ADMIN_USERNAME=Admin
ADMIN_EMAIL=CHANGE_ME_ADMIN_EMAIL@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
