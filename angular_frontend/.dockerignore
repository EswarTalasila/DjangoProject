# =============================================================================
# Frontend .dockerignore
# =============================================================================
# Excludes files from Docker build context to speed up builds and reduce image size.
# This file prevents unnecessary files from being sent to the Docker daemon.

# -----------------------------------------------------------------------------
# Dependencies (reinstalled in container)
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output (rebuilt in container)
# -----------------------------------------------------------------------------
dist/
.angular/

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
test-results/
playwright-report/
blob-report/
coverage/

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git/
.gitignore

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md
!README.md

# -----------------------------------------------------------------------------
# Local environment files
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
._*

# -----------------------------------------------------------------------------
# Playwright browser binaries (downloaded in container)
# -----------------------------------------------------------------------------
playwright/
