# =============================================================================
# Frontend Development Dockerfile
# =============================================================================
# Optimized for fast iterative rebuilds in Docker Compose.
# Dependencies are installed at container start into a persisted named volume,
# so image rebuilds do not re-run npm dependency installation.
# =============================================================================

FROM node:22-alpine

WORKDIR /app

# Chromium supports browser-driven test workflows when executed in this image.
RUN apk add --no-cache chromium

ENV CHROME_BIN=/usr/bin/chromium
ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

CMD ["npm", "run", "dev"]
